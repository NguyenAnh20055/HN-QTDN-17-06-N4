<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_van_ban_den_form" model="ir.ui.view">
            <field name="name">van_ban_den.form</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <form>

                    <header>
                        <field name="trang_thai"
                               widget="statusbar"
                               options="{'clickable': 1}"/>
                    </header>

                    <sheet>

                        <div class="oe_title">
                            <h1>
                                <field name="ten"/>
                            </h1>
                        </div>

                        <group string="Thông tin chung">

                            <group>
                                <field name="ma"/>
                                <field name="ten"/>
                                <field name="loai_van_ban_id"/>
                                <field name="thoi_gian"/>
                                <field name="khach_hang_id"/>
                            </group>

                            <group>
                                <field name="nhan_vien_phu_trach_id"/>
                                <field name="ky_xac_nhan"/>
                                <field name="han"/>
                                <field name="trang_thai"/>
                            </group>

                        </group>

                        <notebook>

                            <page string="File đính kèm">
                                <field name="file_dinh_kem"
                                       widget="pdf_viewer"
                                       string="Xem nội dung"/>
                            </page>

                        </notebook>

                    </sheet>

                </form>
            </field>
        </record>


        <record id="view_van_ban_den_tree" model="ir.ui.view">
            <field name="name">van_ban_den.tree</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <tree>

                    <field name="ma"/>
                    <field name="ten"/>
                    <field name="loai_van_ban_id"/>
                    <field name="thoi_gian"/>
                    <field name="khach_hang_id"/>
                    <field name="nhan_vien_phu_trach_id"/>
                    <field name="ky_xac_nhan"/>
                    <field name="han"/>

                    <field name="file_dinh_kem"
                           widget="binary"
                           filename="ma"
                           string="Tải file"/>
                    <field name="trang_thai" widget="badge"/>
                </tree>
            </field>
        </record>


        <record id="van_ban_den_search" model="ir.ui.view">
            <field name="name">van_ban_den.search</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <search>

                    <field name="ma"/>
                    <field name="ten"/>
                    <field name="loai_van_ban_id"/>
                    <field name="khach_hang_id"/>
                    <field name="nhan_vien_phu_trach_id"/>
                    <field name="trang_thai"/>

                    <group expand="0" string="Nhóm theo">

                        <filter name="group_loai_van_ban"
                                string="Loại văn bản"
                                context="{'group_by':'loai_van_ban_id'}"/>

                        <filter name="group_khach_hang"
                                string="Khách hàng"
                                context="{'group_by':'khach_hang_id'}"/>

                        <filter name="group_nhan_vien"
                                string="Nhân viên"
                                context="{'group_by':'nhan_vien_phu_trach_id'}"/>

                        <filter name="group_trang_thai"
                                string="Trạng thái"
                                context="{'group_by':'trang_thai'}"/>

                    </group>

                </search>
            </field>
        </record>


        <record id="action_van_ban_den" model="ir.actions.act_window">
            <field name="name">Văn bản đến</field>
            <field name="res_model">van_ban_den</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>