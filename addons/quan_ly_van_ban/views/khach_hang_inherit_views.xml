<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_khach_hang_form_inherit_van_ban"
            model="ir.ui.view">

        <field name="name">khach_hang.form.inherit.van.ban</field>

        <field name="model">khach_hang</field>

        <field name="inherit_id"
               ref="quan_ly_khach_hang.view_khach_hang_form"/>

        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page string="Văn bản đi">

                    <field name="van_ban_di_ids" readonly="1">

                        <tree>

                            <field name="ma"/>
                            <field name="ten"/>
                            <field name="loai_van_ban_id"/>
                            <field name="thoi_gian"/>
                            <field name="trang_thai"/>

                        </tree>

                    </field>

                </page>

                <page string="Văn bản đến">

                    <field name="van_ban_den_ids" readonly="1">

                        <tree>

                            <field name="ma"/>
                            <field name="ten"/>
                            <field name="loai_van_ban_id"/>
                            <field name="thoi_gian"/>
                            <field name="trang_thai"/>

                        </tree>

                    </field>

                </page>

            </xpath>

        </field>

    </record>

</odoo>