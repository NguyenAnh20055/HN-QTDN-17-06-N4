<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- FORM -->
        <record id="view_van_ban_noi_bo_form" model="ir.ui.view">
            <field name="name">van_ban_noi_bo.form</field>
            <field name="model">van_ban_noi_bo</field>
            <field name="arch" type="xml">
                <form>

                    <header>
                        <field name="trang_thai"
                               widget="statusbar"
                               options="{'clickable':1}"/>
                    </header>

                    <sheet>

                        <div class="oe_title">
                            <h1>
                                <field name="ten"/>
                            </h1>
                        </div>

                        <group string="Thông tin chung">

                            <group>
                                <field name="ma"/>
                                <field name="ten"/>
                                <field name="thoi_gian"/>
                                <field name="loai_van_ban_id"/>
                                <field name="nguoi_gui"/>
                            </group>

                            <group>
                                <field name="nguoi_nhan"/>
                                <field name="trang_thai"/>
                                <field name="mo_ta"/>
                            </group>

                        </group>

                        <notebook>

                            <page string="File đính kèm">

                                <field name="file_dinh_kem"
                                       widget="pdf_viewer"
                                       string="Xem trực tiếp"/>

                            </page>

                        </notebook>

                    </sheet>

                </form>

            </field>

        </record>


        <!-- TREE -->
        <record id="view_van_ban_noi_bo_tree" model="ir.ui.view">
            <field name="name">van_ban_noi_bo.tree</field>
            <field name="model">van_ban_noi_bo</field>
            <field name="arch" type="xml">

                <tree>

                    <field name="ma"/>
                    <field name="ten"/>
                    <field name="loai_van_ban_id"/>
                    <field name="thoi_gian"/>
                    <field name="nguoi_gui"/>
                    <field name="nguoi_nhan"/>
                    <field name="mo_ta"/>
                    <field name="trang_thai" widget="badge"/>

                </tree>

            </field>
        </record>


        <!-- SEARCH -->
        <record id="van_ban_noi_bo_search" model="ir.ui.view">
            <field name="model">van_ban_noi_bo</field>

            <field name="arch" type="xml">

                <search>

                    <field name="ma"/>
                    <field name="ten"/>
                    <field name="loai_van_ban_id"/>
                    <field name="nguoi_gui"/>
                    <field name="nguoi_nhan"/>
                    <field name="trang_thai"/>

                    <group expand="0" string="Gom nhóm theo">

                        <filter string="Loại văn bản"
                                name="group_type"
                                context="{'group_by':'loai_van_ban_id'}"/>

                        <filter string="Người gửi"
                                name="group_sender"
                                context="{'group_by':'nguoi_gui'}"/>

                        <filter string="Người nhận"
                                name="group_receiver"
                                context="{'group_by':'nguoi_nhan'}"/>

                        <filter string="Trạng thái"
                                name="group_status"
                                context="{'group_by':'trang_thai'}"/>

                    </group>

                </search>

            </field>
        </record>


        <!-- ACTION -->
        <record id="action_van_ban_noi_bo" model="ir.actions.act_window">
            <field name="name">Văn bản nội bộ</field>
            <field name="res_model">van_ban_noi_bo</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>